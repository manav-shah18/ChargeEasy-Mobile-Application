<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:padding="24dp"
    tools:context=".BookingActivity">

    <!-- Title -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Book a Session"
        android:textColor="@android:color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Station Name (from previous screen) -->
    <TextView
        android:id="@+id/tv_station_name_booking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@+id/tv_title"
        tools:text="ImPark Underhill Garage" />

    <!-- Date & Time Selection (in a horizontal row) -->
    <LinearLayout
        android:id="@+id/ll_date_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@+id/tv_station_name_booking">

        <!-- Date Input -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_booking_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:hint="Select Date"
            app:endIconDrawable="@drawable/ic_calendar_small"
            app:endIconMode="custom">

            <EditText
                android:id="@+id/et_booking_date"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- NEW: Start Time Input -->
        <!-- FIX: Added ID 'til_booking_time' to the parent layout -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/til_booking_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:hint="Start Time"
            app:endIconDrawable="@drawable/ic_clock"
            app:endIconMode="custom">

            <EditText
                android:id="@+id/et_booking_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:focusable="false"
                android:clickable="true" />
        </com.google.android.material.textfield.TextInputLayout>

    </LinearLayout>

    <!-- Duration/Time Slot Selection -->
    <TextView
        android:id="@+id/tv_duration_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Select Duration"
        android:textColor="@android:color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/ll_date_time" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_time_slots"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:layout_constraintTop_toBottomOf="@+id/tv_duration_label" />

    <!-- Cost Summary -->
    <TextView
        android:id="@+id/tv_cost_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Estimated Cost"
        android:textColor="@android:color/darker_gray"
        android:textSize="16sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/rv_time_slots" />

    <TextView
        android:id="@+id/tv_estimated_cost"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@android:color/black"
        android:textSize="28sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/tv_cost_label"
        app:layout_constraintBottom_toBottomOf="@+id/tv_cost_label"
        tools:text="$30.00" />

    <!-- Confirm Button -->
    <Button
        android:id="@+id/btn_confirm_booking"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:backgroundTint="@color/green_primary"
        android:text="Confirm &amp; Book"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>